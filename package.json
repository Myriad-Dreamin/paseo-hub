{
  "name": "paseo-hub",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "packageManager": "pnpm@10.17.0",
  "scripts": {
    "dev": "next dev --webpack",
    "build": "next build --webpack",
    "start": "next start",
    "install:paseo": "node server-side/paseo/install.ts",
    "service:install": "powershell -NoProfile -ExecutionPolicy Bypass -File scripts/windows-service.ps1 install",
    "service:uninstall": "powershell -NoProfile -ExecutionPolicy Bypass -File scripts/windows-service.ps1 uninstall",
    "service:start": "powershell -NoProfile -ExecutionPolicy Bypass -File scripts/windows-service.ps1 start",
    "service:stop": "powershell -NoProfile -ExecutionPolicy Bypass -File scripts/windows-service.ps1 stop",
    "service:restart": "powershell -NoProfile -ExecutionPolicy Bypass -File scripts/windows-service.ps1 restart",
    "service:status": "powershell -NoProfile -ExecutionPolicy Bypass -File scripts/windows-service.ps1 status"
  },
  "dependencies": {
    "next": "^16.2.6",
    "react": "^19.2.6",
    "react-dom": "^19.2.6"
  },
  "devDependencies": {
    "@types/node": "^25.8.0",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "typescript": "^6.0.3"
  }
}
